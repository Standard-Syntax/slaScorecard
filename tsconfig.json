{
    "compilerOptions": {
        "allowJs": false,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "es2022",
        "sourceMap": true,
        "outDir": "./.tmp/build/",
        "moduleResolution": "bundler",
        "module": "esnext",
        "declaration": true,
        "strict": true,
        "skipLibCheck": true,
        "lib": [
            "es2022",
            "dom"
        ]
    },
    "files": [
        "./src/visual.ts",
        "./src/settings.ts",
        "./src/types.ts",
        "./src/bulletChart.ts",
        "./src/sparkline.ts",
        "./src/components.ts"
    ],
    "include": [
        "./src/**/*.ts",
        "./*.d.ts"
    ]
}